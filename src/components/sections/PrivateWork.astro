---
// PrivateWork.astro — Behind closed doors: private repos organized by domain
// Data-driven: categories and repos sourced from src/data/private-repos.json at build time
import privateReposData from '../../data/private-repos.json';
---

<section class="privatework" id="privatework">
  <p class="section-moral"><em>Not every grape the fox reached was sour; some were simply private.</em></p>

  <h2>Behind closed doors</h2>

  <p class="intro-line">31 private repositories; a selection, one line each.</p>

  <div class="category-grid">
    {privateReposData.categories.map((category) => (
      <div class="category">
        <h3>{category.name}</h3>
        <ul class="repo-list">
          {category.repos.map((repo) => (
            <li><strong>{repo.name}</strong> — {repo.description}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .privatework {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: var(--width-container);
    margin: 0 auto var(--space-20);
    padding: var(--space-8);
  }

  .privatework .section-moral {
    margin: 0;
  }

  /* Override shared section h2 to match PrivateWork's smaller size and no top margin */
  .privatework h2 {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .intro-line {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(28ch, 1fr));
    gap: var(--space-6);
    align-items: start;
  }

  .category {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .category h3 {
    font-size: var(--text-base);
    color: var(--accent);
    font-weight: 600;
    margin: 0;
    line-height: var(--leading-tight);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .repo-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .repo-list li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    word-wrap: break-word;
  }

  .repo-list strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Focus rings on interactive elements (if needed) */
  .category:focus-within {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .category {
      transition: none;
    }
  }

  /* Responsive: stack grid on smaller screens */
  @media (max-width: 640px) {
    .category-grid {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: var(--text-xl);
    }

    .privatework {
      padding: var(--space-4);
      gap: var(--space-6);
    }
  }
</style>
