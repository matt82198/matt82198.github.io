---
// Writing section: Medium essays, data-driven
// Featured essays and additional articles sourced from src/data/writing.json at build time
import writingData from '../../data/writing.json';

// Helper to format dates from ISO to readable format
function formatDate(isoDate: string): string {
  const date = new Date(isoDate);
  const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
  return date.toLocaleDateString('en-US', options);
}
---

<section class="writing-section">
  <p class="section-moral">
    <em>The crow wrote down what the pitcher taught it.</em>
  </p>

  <h2 id="writing">Writing</h2>

  <!-- Featured essays: first two with visual prominence -->
  <div class="featured-essays">
    {writingData.featured.map((essay) => (
      <article class="featured-essay">
        <a href={essay.url} class="essay-link">
          <h3>{essay.title}</h3>
        </a>
        <time datetime={essay.date} class="essay-date">{formatDate(essay.date)}</time>
        <p class="essay-desc">{essay.description}</p>
      </article>
    ))}
  </div>

  <!-- Additional essays: compact list -->
  <ul class="essay-list">
    {writingData.additional.map((essay) => (
      <li>
        <span class="essay-title">
          <a href={essay.url} class="list-link">
            {essay.title}
          </a>
        </span>
        <span class="essay-meta">
          <time datetime={essay.date}>{formatDate(essay.date)}</time>
          — {essay.description}
        </span>
      </li>
    ))}
  </ul>
</section>

<style>
  .writing-section {
    margin-bottom: var(--space-20);
  }

  /* Use shared .section-moral and section h2 from global.css */

  /* Featured essays grid */
  .featured-essays {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-16);
  }

  .featured-essay {
    padding: var(--space-8);
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    border-radius: 8px;
    transition: background-color var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-essay {
      transition: none;
    }
  }

  .featured-essay:hover {
    background: var(--color-bg);
    border-color: var(--accent);
  }

  .essay-link {
    text-decoration: none;
    color: inherit;
  }

  .essay-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: 0.25rem;
  }

  .featured-essay h3 {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-4) 0;
    font-family: var(--font-sans);
    line-height: var(--leading-normal);
  }

  .essay-date {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    display: block;
    margin-bottom: var(--space-3);
  }

  .essay-desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0;
    font-family: var(--font-sans);
    line-height: var(--leading-normal);
  }

  /* Essay list */
  .essay-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .essay-list li {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border-subtle);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .essay-list li:last-child {
    border-bottom: none;
  }

  .essay-title {
    display: block;
  }

  .list-link {
    font-size: var(--text-base);
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    font-family: var(--font-sans);
    line-height: var(--leading-normal);
    transition: color var(--duration-fast) var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .list-link {
      transition: none;
    }
  }

  .list-link:hover {
    color: var(--accent-light);
  }

  .list-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: 0.125rem;
  }

  .essay-meta {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
    line-height: var(--leading-normal);
  }

  .essay-meta time {
    font-family: var(--font-mono);
    color: var(--color-text-tertiary);
  }
</style>
