---
// Hero section — full-viewport landing statement
// Data-count values and JS fallbacks derived from src/data/aesop-stats.json at build time
import stats from '../../data/aesop-stats.json';
---

<section class="hero" id="hero">
  <div class="hero-content">
    <p class="section-moral"><em>The best systems are those that build themselves.</em></p>

    <h1 class="hero-title">MATT CULLITON</h1>

    <p class="hero-tagline">I build software fleets that build software.</p>

    <p class="hero-subhead">
      AI orchestration · full-stack automation · production systems that ship themselves
    </p>

    <div class="hero-stats">
      <div class="stats-header">
        <span class="live-badge" id="live-badge" title="Stats syncing from GitHub API and stats.json">● live</span>
      </div>
      <div class="stat">
        <span class="stat-number" data-count={stats.merged_prs}>{stats.merged_prs}</span> PRs merged by a self-building system
      </div>
      <div class="stat">
        <span class="stat-number" data-count={stats.waves}>{stats.waves}</span> development waves
      </div>
      <div class="stat">
        <span class="stat-number" data-count={stats.loc}>{(stats.loc / 1000).toFixed(1)}K</span> lines of code
      </div>
      <div class="stat">
        <span class="stat-number" data-count={stats.commits}>{stats.commits}</span> commits
      </div>
      <div class="stat">
        <span class="stat-number" data-count={stats.coauthors}>{stats.coauthors}</span> co-authors on the fleet
      </div>
    </div>
    <p class="sync-status" id="sync-status"></p>

    <p class="hero-kicker"><em>This site was assembled by the fleet it describes.</em></p>

    <div class="hero-links">
      <a href="https://github.com/matt82198" class="hero-link">GitHub</a>
      <span class="link-divider">·</span>
      <a href="https://medium.com/@matt82198" class="hero-link">Medium</a>
      <span class="link-divider">·</span>
      <a href="https://linkedin.com/in/matt-culliton-a8327676" class="hero-link">LinkedIn</a>
    </div>

    <p class="hero-moral"><em>Slow and steady wins; parallel and verified wins sooner.</em></p>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    min-height: 100dvh;
    padding: var(--space-8);
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  .hero-content {
    max-width: var(--width-prose);
    text-align: center;
  }

  .section-moral {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin: 0 0 var(--space-8) 0;
    font-family: var(--font-sans);
    letter-spacing: var(--tracking-normal);
  }

  .section-moral em {
    font-style: italic;
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: var(--space-8) 0 var(--space-6) 0;
    line-height: var(--leading-tight);
  }

  .hero-tagline {
    font-size: var(--text-2xl);
    font-family: var(--font-sans);
    color: var(--color-text);
    margin: 0 0 var(--space-4) 0;
    line-height: var(--leading-normal);
    font-weight: 400;
  }

  .hero-subhead {
    font-size: var(--text-base);
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-12) 0;
    line-height: var(--leading-normal);
  }

  .hero-stats {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    padding: var(--space-8);
    margin: 0 0 var(--space-12) 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .stats-header {
    margin-bottom: var(--space-4);
  }

  .live-badge {
    font-size: var(--text-xs);
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.05em;
    opacity: 0.8;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-badge {
      animation: none;
      opacity: 0.8;
    }
  }

  .stat {
    color: var(--color-text-secondary);
  }

  .stat:not(:last-child) {
    margin-bottom: var(--space-4);
  }

  .stat-number {
    color: var(--accent);
    font-weight: 700;
    min-width: 3ch;
    font-variant-numeric: tabular-nums;
  }

  .sync-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-align: center;
    margin: 0;
    min-height: 1.2em;
  }

  .hero-kicker {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-style: italic;
    margin: 0 0 var(--space-8) 0;
    line-height: var(--leading-normal);
    font-family: var(--font-sans);
  }

  .hero-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-4);
    margin: 0 0 var(--space-12) 0;
    flex-wrap: wrap;
  }

  .hero-link {
    color: var(--accent);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-3);
    transition: color var(--duration-base) var(--ease-out);
  }

  .hero-link:hover {
    color: var(--accent-light);
  }

  .hero-link:focus {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .link-divider {
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  .hero-moral {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin: 0;
    font-family: var(--font-sans);
  }

  .hero-moral em {
    font-style: italic;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-link {
      transition: none;
    }
  }
</style>

<script define:vars={{ bakedStats: stats }} is:inline>
(function() {
  // Live stats from GitHub API (PRs) + stats.json (commits, waves, co-authors, LOC)
  // Graceful degradation: baked fallbacks on any failure
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const REPO = 'matt82198/aesop';

  let liveData = {};
  const statusEl = document.getElementById('sync-status');
  const badgeEl = document.getElementById('live-badge');

  async function fetchLiveStats() {
    try {
      // Fetch merged PRs from GitHub search API (accurate)
      const prRes = await fetch(`https://api.github.com/search/issues?q=repo:${REPO}+type:pr+is:merged&per_page=1`);
      if (prRes.ok) {
        const prData = await prRes.json();
        liveData.mergedPRs = prData.total_count || bakedStats.merged_prs;
      }

      // Fetch repo info for last push time
      const repoRes = await fetch(`https://api.github.com/repos/${REPO}`);
      if (repoRes.ok) {
        const repoData = await repoRes.json();
        liveData.stars = repoData.stargazers_count || 0;
        if (repoData.pushed_at) {
          liveData.lastPush = new Date(repoData.pushed_at);
        }
      }

      // Fetch stats.json for git-derived stats (commits, waves, co-authors, LOC)
      const statsRes = await fetch(`https://raw.githubusercontent.com/${REPO}/main/stats.json`);
      if (statsRes.ok) {
        const statsFile = await statsRes.json();
        // Navigate the nested structure: stats.json has { git: { total_commits, wave_count, distinct_coauthors }, loc: ... }
        if (statsFile.git) {
          liveData.commits = statsFile.git.total_commits || bakedStats.commits;
          liveData.waves = statsFile.git.wave_count || bakedStats.waves;
          liveData.coauthors = statsFile.git.distinct_coauthors || bakedStats.coauthors;
          liveData.loc = statsFile.loc || bakedStats.loc;
        } else {
          // Fallback if nested structure is different
          liveData.commits = bakedStats.commits;
          liveData.waves = bakedStats.waves;
          liveData.coauthors = bakedStats.coauthors;
          liveData.loc = bakedStats.loc;
        }
      } else {
        // Fallback if stats.json doesn't exist yet
        liveData.commits = bakedStats.commits;
        liveData.waves = bakedStats.waves;
        liveData.coauthors = bakedStats.coauthors;
        liveData.loc = bakedStats.loc;
      }

      return true;
    } catch (err) {
      // Silently fail — keep baked values
      return false;
    }
  }

  function formatRelativeTime(date) {
    if (!date) return '';
    const now = new Date();
    const diff = now - date;
    const seconds = Math.floor(diff / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    const days = Math.floor(hours / 24);

    if (days > 0) return `${days}d ago`;
    if (hours > 0) return `${hours}h ago`;
    if (minutes > 0) return `${minutes}m ago`;
    return 'just now';
  }

  function updateStats() {
    // Map live data to DOM elements
    const updates = [
      { attr: 'data-count', key: 'mergedPRs', selector: `[data-count="${bakedStats.merged_prs}"]` },
      { attr: 'data-count', key: 'waves', selector: `[data-count="${bakedStats.waves}"]` },
      { attr: 'data-count', key: 'loc', selector: `[data-count="${bakedStats.loc}"]` },
      { attr: 'data-count', key: 'commits', selector: `[data-count="${bakedStats.commits}"]` },
      { attr: 'data-count', key: 'coauthors', selector: `[data-count="${bakedStats.coauthors}"]` },
    ];

    updates.forEach(({ key, selector }) => {
      const el = document.querySelector(selector);
      if (el && liveData[key]) {
        const oldValue = parseInt(el.dataset.count, 10);
        const newValue = liveData[key];
        el.dataset.count = newValue;
        animateCount(el, oldValue, newValue);
      }
    });

    // Update sync status with relative time
    if (liveData.lastPush) {
      const relTime = formatRelativeTime(liveData.lastPush);
      if (statusEl) {
        statusEl.textContent = `synced from GitHub · updated ${relTime}`;
      }
    }
  }

  function animateCount(el, from, to) {
    if (prefersReducedMotion || from === to) {
      // Instant update on reduced motion or no change
      el.textContent = to.toLocaleString('en-US');
      return;
    }

    const duration = 1500;
    const start = Date.now();

    const update = () => {
      const elapsed = Date.now() - start;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.floor(from + (to - from) * progress);
      el.textContent = current.toLocaleString('en-US');

      if (progress < 1) {
        requestAnimationFrame(update);
      } else {
        el.textContent = to.toLocaleString('en-US');
      }
    };

    update();
  }

  function setupStatAnimation() {
    // Animate baked stats on page load (count-up from 0)
    if (prefersReducedMotion) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !entry.target.classList.contains('animated')) {
          const elements = entry.target.querySelectorAll('[data-count]');
          elements.forEach(el => {
            const target = parseInt(el.dataset.count, 10);
            animateCount(el, 0, target);
          });
          entry.target.classList.add('animated');
        }
      });
    }, { threshold: 0.1 });

    const statsSection = document.querySelector('.hero-stats');
    if (statsSection) {
      observer.observe(statsSection);
    }
  }

  // On page load: setup animation + fetch live stats
  setupStatAnimation();
  fetchLiveStats().then(success => {
    if (success) {
      updateStats();
    }
  });
})();
</script>
