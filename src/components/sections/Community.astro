---
// Community section: field notes shared on Reddit
// Data-driven: posts sourced from src/data/community-posts.json at build time
import communityData from '../../data/community-posts.json';
---

<section class="community-section">
  <p class="section-moral">
    <em>The shepherd posted his flock's numbers; the wolves already knew theirs.</em>
  </p>

  <h2 id="community">Community — field notes in public</h2>

  <p class="community-intro">
    Writes on Reddit as <a href="https://reddit.com/user/rehtorical" class="reddit-link">u/rehtorical</a>.
    <span class="community-theme">token economics · agent orchestration · AI security</span>
  </p>

  <!-- Featured post -->
  <div class="featured-post">
    <div class="featured-badge">FEATURED</div>
    <article class="reddit-post">
      <a href={communityData.featured.url} class="post-link">
        <h3>{communityData.featured.title}</h3>
      </a>
      <p class="post-meta">{communityData.featured.subreddit} · {communityData.featured.meta}</p>
      <p class="post-desc">{communityData.featured.description}</p>
    </article>
  </div>

  <!-- Additional posts -->
  <ul class="post-list">
    {communityData.additional.map((post) => (
      <li>
        <article class="reddit-post">
          <a href={post.url} class="post-link">
            <h3>{post.title}</h3>
          </a>
          <p class="post-meta">
            {post.subreddit} {post.upvotes ? `· ${post.upvotes} upvotes` : ''}
          </p>
          <p class="post-desc">{post.description}</p>
        </article>
      </li>
    ))}
  </ul>
</section>

<style>
  .community-section {
    margin-bottom: var(--space-20);
  }

  /* Use shared .section-moral and section h2 from global.css */

  .community-intro {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-12);
    font-family: var(--font-sans);
    line-height: var(--leading-normal);
  }

  .reddit-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: color var(--duration-fast) var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .reddit-link {
      transition: none;
    }
  }

  .reddit-link:hover {
    color: var(--accent-light);
  }

  .reddit-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: 0.125rem;
  }

  .community-theme {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-top: var(--space-2);
    font-style: italic;
    font-family: var(--font-sans);
  }

  /* Featured post section */
  .featured-post {
    position: relative;
    margin-bottom: var(--space-16);
  }

  .featured-badge {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-3);
    font-family: var(--font-mono);
  }

  .reddit-post {
    padding: var(--space-8);
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    border-radius: 8px;
    transition: background-color var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .reddit-post {
      transition: none;
    }
  }

  .reddit-post:hover {
    background: var(--color-bg);
    border-color: var(--accent);
  }

  .post-link {
    text-decoration: none;
    color: inherit;
  }

  .post-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: 0.25rem;
  }

  .reddit-post h3 {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3) 0;
    font-family: var(--font-sans);
    line-height: var(--leading-normal);
  }

  .post-meta {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    margin: 0 0 var(--space-3) 0;
  }

  .post-desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0;
    font-family: var(--font-sans);
    line-height: var(--leading-normal);
  }

  /* Post list */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-8);
  }

  .post-list li {
    display: flex;
  }

  .post-list .reddit-post {
    width: 100%;
  }
</style>
