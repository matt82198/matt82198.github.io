---
// FleetViz.astro — Animation of the dispatch model: orchestrator + workers
// Self-contained inline SVG + vanilla JS, no external dependencies
---

<section class="fleet-viz-section">
  <p class="section-moral"><em>Many hands, one moral: ship.</em></p>

  <h2 id="fleet">The fleet, at work</h2>

  <div class="viz-container">
    <svg class="fleet-diagram" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Live Haiku worker dispatch orchestration">
      <defs>
        <style>
          .orchestrator-node { fill: var(--accent); }
          .worker-dot { fill: var(--color-text-secondary); }
          /* Brief lines: use accent with full opacity for visibility in both light and dark modes */
          .brief-line { stroke: var(--accent); stroke-width: 1.5; fill: none; opacity: 0.8; }
          /* Path guides: use text-secondary with increased opacity for visibility */
          .path-line { stroke: var(--color-text-secondary); stroke-width: 1; fill: none; opacity: 0.25; }
        </style>
      </defs>

      <!-- Static path guides (background) — dynamically created based on live worker count -->
      <g class="paths" id="paths-group"></g>

      <!-- Static brief lines (converging on return) — dynamically created -->
      <g class="brief-lines" id="brief-lines-group"></g>

      <!-- Orchestrator center node -->
      <circle class="orchestrator-node" cx="200" cy="150" r="8" />

      <!-- Worker dots — dynamically created based on live contributor count -->
      <g class="workers" id="workers-group"></g>

      <!-- Info label: wave count (static or from stats.json) -->
      <text id="wave-label" x="200" y="30" text-anchor="middle" font-family="var(--font-mono)" font-size="12" fill="var(--accent)" opacity="0.6"></text>
    </svg>

    <!-- Mono caption cycling through phases -->
    <p class="phase-caption"><code id="phase-text">dispatch</code></p>

    <!-- Legend -->
    <p class="fleet-legend">Live orchestration: <span id="live-worker-count">7</span> Haiku workers, wave <span id="live-wave-count">15</span></p>
  </div>
</section>

<style>
  .fleet-viz-section {
    margin-bottom: var(--space-16);
  }

  /* Override shared section h2 to match FleetViz's smaller size */
  .fleet-viz-section h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
  }

  .viz-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  .fleet-diagram {
    width: 100%;
    max-width: 500px;
    height: auto;
    aspect-ratio: 400 / 300;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
  }

  .fleet-diagram:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .phase-caption {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    min-height: 1.5em;
  }

  #phase-text {
    color: var(--accent);
    font-weight: 500;
  }

  .fleet-legend {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-align: center;
    max-width: 60ch;
    margin: 0;
    line-height: var(--leading-normal);
  }

  /* Reduce motion: show static diagram */
  @media (prefers-reduced-motion: reduce) {
    .orchestrator-node {
      opacity: 1;
    }

    .worker-dot {
      opacity: 1;
    }
  }
</style>

<script is:inline>
(function() {
  const svg = document.querySelector('.fleet-diagram');
  const phaseText = document.getElementById('phase-text');
  const workersGroupEl = document.getElementById('workers-group');
  const briefLinesGroupEl = document.getElementById('brief-lines-group');
  const pathsGroupEl = document.getElementById('paths-group');
  const workerCountEl = document.getElementById('live-worker-count');
  const waveCountEl = document.getElementById('live-wave-count');
  const waveLabel = document.getElementById('wave-label');

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Live state
  let numWorkers = 7; // default
  let waveCount = 15; // default
  let workers = [];
  let endpoints = [];
  let controlPoints = [];

  const phases = ['dispatch', 'build', 'verify', 'merge'];
  let currentPhase = 0;
  let animationStartTime = 0;
  let isSwarming = false;
  let swarmTime = 0;
  const swarmDuration = 800;
  let cycleDuration = 6000; // Will adjust based on activity

  // Generate endpoints and control points based on worker count
  function generateLayout() {
    endpoints = [];
    controlPoints = [];

    if (numWorkers === 0) numWorkers = 1;

    const angleStep = (Math.PI * 2) / numWorkers;
    const radius = 130;

    for (let i = 0; i < numWorkers; i++) {
      const angle = angleStep * i - Math.PI / 2;
      endpoints.push({
        x: 200 + Math.cos(angle) * radius,
        y: 150 + Math.sin(angle) * radius
      });
      controlPoints.push({
        x: 200 + Math.cos(angle) * 70,
        y: 150 + Math.sin(angle) * 70
      });
    }
  }

  // Create SVG elements for paths, brief lines, and workers
  function renderLayout() {
    // Clear existing
    pathsGroupEl.innerHTML = '';
    briefLinesGroupEl.innerHTML = '';
    workersGroupEl.innerHTML = '';

    // Create path guides
    endpoints.forEach((endpoint, i) => {
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('class', 'path-line');
      path.setAttribute('d', `M 200 150 Q ${controlPoints[i].x} ${controlPoints[i].y} ${endpoint.x} ${endpoint.y}`);
      pathsGroupEl.appendChild(path);
    });

    // Create worker dots
    workers = [];
    endpoints.forEach((endpoint, i) => {
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('class', 'worker-dot');
      circle.setAttribute('data-index', i);
      circle.setAttribute('cx', endpoint.x);
      circle.setAttribute('cy', endpoint.y);
      circle.setAttribute('r', '5');
      workersGroupEl.appendChild(circle);
      workers.push(circle);
    });

    // Create initial brief lines
    endpoints.forEach((endpoint) => {
      const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      line.setAttribute('class', 'brief-line');
      line.setAttribute('x1', endpoint.x);
      line.setAttribute('y1', endpoint.y);
      line.setAttribute('x2', 200);
      line.setAttribute('y2', 150);
      briefLinesGroupEl.appendChild(line);
    });
  }

  function quadraticBezier(t, p0, p1, p2) {
    return (1 - t) * (1 - t) * p0 + 2 * (1 - t) * t * p1 + t * t * p2;
  }

  function getPositionOnPath(t, idx) {
    const endpoint = endpoints[idx];
    const controlPoint = controlPoints[idx];
    const x = quadraticBezier(t, 200, controlPoint.x, endpoint.x);
    const y = quadraticBezier(t, 150, controlPoint.y, endpoint.y);
    return { x, y };
  }

  function updatePhaseCaption() {
    phaseText.textContent = phases[currentPhase];
  }

  function animate(timestamp) {
    if (!animationStartTime) animationStartTime = timestamp;
    const elapsed = timestamp - animationStartTime;

    // Phase cycling
    const phaseIndex = Math.floor((elapsed / 3000) % phases.length);
    if (phaseIndex !== currentPhase) {
      currentPhase = phaseIndex;
      updatePhaseCaption();
    }

    const cycleTime = (elapsed % cycleDuration);

    if (cycleTime < cycleDuration * 0.33) {
      // Dispatch phase: move out
      const t = cycleTime / (cycleDuration * 0.33);
      workers.forEach((worker, idx) => {
        const pos = getPositionOnPath(t, idx);
        worker.setAttribute('cx', pos.x);
        worker.setAttribute('cy', pos.y);
      });
      // Clear dynamic brief lines during dispatch
      Array.from(briefLinesGroupEl.querySelectorAll('line')).forEach(line => {
        if (line.getAttribute('data-dynamic')) line.remove();
      });
    } else if (cycleTime < cycleDuration * 0.67) {
      // Return phase: move back
      const t = 1 - ((cycleTime - cycleDuration * 0.33) / (cycleDuration * 0.33));
      Array.from(briefLinesGroupEl.querySelectorAll('line')).forEach(line => {
        if (line.getAttribute('data-dynamic')) line.remove();
      });

      workers.forEach((worker, idx) => {
        const pos = getPositionOnPath(t, idx);
        worker.setAttribute('cx', pos.x);
        worker.setAttribute('cy', pos.y);

        // Draw brief line from worker back to orchestrator
        if (t < 0.9 && t > 0.1) {
          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('class', 'brief-line');
          line.setAttribute('data-dynamic', 'true');
          line.setAttribute('x1', pos.x);
          line.setAttribute('y1', pos.y);
          line.setAttribute('x2', 200);
          line.setAttribute('y2', 150);
          briefLinesGroupEl.appendChild(line);
        }
      });
    } else {
      // Rest phase: dots return to center
      workers.forEach((worker) => {
        worker.setAttribute('cx', 200);
        worker.setAttribute('cy', 150);
      });
      Array.from(briefLinesGroupEl.querySelectorAll('line')).forEach(line => {
        if (line.getAttribute('data-dynamic')) line.remove();
      });
    }

    // Swarm effect on click
    if (isSwarming) {
      swarmTime += 16;
      if (swarmTime < swarmDuration) {
        const swarmT = Math.sin((swarmTime / swarmDuration) * Math.PI);
        workers.forEach((worker, idx) => {
          const baseAngle = (idx / numWorkers) * Math.PI * 2;
          const swarmRadius = 40 * swarmT;
          const swarmX = 200 + Math.cos(baseAngle) * swarmRadius;
          const swarmY = 150 + Math.sin(baseAngle) * swarmRadius;
          worker.setAttribute('cx', swarmX);
          worker.setAttribute('cy', swarmY);
        });
      } else {
        isSwarming = false;
        swarmTime = 0;
      }
    }

    if (!prefersReducedMotion) {
      requestAnimationFrame(animate);
    }
  }

  async function fetchLiveData() {
    try {
      const REPO = 'matt82198/aesop';

      // Fetch stats.json for co-author count (workers) and wave count
      const statsRes = await fetch(`https://raw.githubusercontent.com/${REPO}/main/stats.json`);
      if (statsRes.ok) {
        const statsData = await statsRes.json();
        // Navigate the nested structure: stats.json has { git: { distinct_coauthors, wave_count } }
        if (statsData.git) {
          // Use co-author count for worker count (7), capped at 12 for layout
          numWorkers = Math.min(statsData.git.distinct_coauthors || 7, 12);
          waveCount = statsData.git.wave_count || 16;
        } else {
          // Fallback if structure is different
          numWorkers = 7;
          waveCount = 16;
        }
        workerCountEl.textContent = numWorkers;
        waveCountEl.textContent = waveCount;
        waveLabel.textContent = `wave ${waveCount}`;
      } else {
        // Fallback if stats.json doesn't exist yet
        numWorkers = 7;
        waveCount = 16;
        workerCountEl.textContent = numWorkers;
        waveCountEl.textContent = waveCount;
        waveLabel.textContent = `wave ${waveCount}`;
      }

      // Adjust cycle duration based on activity: recent push = faster cycle
      const repoRes = await fetch(`https://api.github.com/repos/${REPO}`);
      if (repoRes.ok) {
        const repoData = await repoRes.json();
        if (repoData.pushed_at) {
          const lastPush = new Date(repoData.pushed_at);
          const minutesAgo = (Date.now() - lastPush) / (1000 * 60);
          // Recent activity = faster cycle (4s), old activity = slower (7s)
          cycleDuration = minutesAgo < 60 ? 4000 : 7000;
        }
      }
    } catch (err) {
      // Silent fail, use defaults (7 workers, 16 waves)
    }
  }

  // Initialize
  generateLayout();
  renderLayout();
  fetchLiveData().then(() => {
    generateLayout();
    renderLayout();
  });

  // Interaction
  svg.addEventListener('click', (e) => {
    const rect = svg.getBoundingClientRect();
    const clickX = (e.clientX - rect.left) / rect.width * 400;
    const clickY = (e.clientY - rect.top) / rect.height * 300;
    const dist = Math.sqrt((clickX - 200) ** 2 + (clickY - 150) ** 2);
    if (dist < 20) {
      isSwarming = true;
      swarmTime = 0;
    }
  });

  svg.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      isSwarming = true;
      swarmTime = 0;
    }
  });

  svg.setAttribute('tabindex', '0');

  if (!prefersReducedMotion) {
    requestAnimationFrame(animate);
  }
})();
</script>
