---
// FleetViz.astro — Animation of the dispatch model: orchestrator + workers
// Self-contained inline SVG + vanilla JS, no external dependencies
---

<section class="fleet-viz-section">
  <p class="section-moral"><em>Many hands, one moral: ship.</em></p>

  <h2 id="fleet">The fleet, at work</h2>

  <div class="viz-container">
    <svg class="fleet-diagram" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Orchestrator dispatching 7 Haiku workers in a fan-out pattern">
      <defs>
        <style>
          .orchestrator-node { fill: var(--accent); }
          .worker-dot { fill: var(--color-text-secondary); }
          .brief-line { stroke: var(--accent-light); stroke-width: 1.5; fill: none; opacity: 0.6; }
          .path-line { stroke: var(--color-border); stroke-width: 1; fill: none; opacity: 0.3; }
        </style>
      </defs>

      <!-- Static path guides (background) -->
      <g class="paths">
        <path class="path-line" d="M 200 150 Q 280 80 340 50" />
        <path class="path-line" d="M 200 150 Q 300 100 360 100" />
        <path class="path-line" d="M 200 150 Q 300 150 370 150" />
        <path class="path-line" d="M 200 150 Q 300 200 360 200" />
        <path class="path-line" d="M 200 150 Q 280 220 340 250" />
        <path class="path-line" d="M 200 150 Q 220 80 80 50" />
        <path class="path-line" d="M 200 150 Q 100 100 40 100" />
      </g>

      <!-- Brief lines (converging on return) -->
      <g class="brief-lines"></g>

      <!-- Orchestrator center node -->
      <circle class="orchestrator-node" cx="200" cy="150" r="8" />

      <!-- Worker dots -->
      <g class="workers">
        <circle class="worker-dot" data-index="0" cx="200" cy="150" r="5" />
        <circle class="worker-dot" data-index="1" cx="200" cy="150" r="5" />
        <circle class="worker-dot" data-index="2" cx="200" cy="150" r="5" />
        <circle class="worker-dot" data-index="3" cx="200" cy="150" r="5" />
        <circle class="worker-dot" data-index="4" cx="200" cy="150" r="5" />
        <circle class="worker-dot" data-index="5" cx="200" cy="150" r="5" />
        <circle class="worker-dot" data-index="6" cx="200" cy="150" r="5" />
      </g>
    </svg>

    <!-- Mono caption cycling through phases -->
    <p class="phase-caption"><code id="phase-text">dispatch</code></p>

    <!-- Legend -->
    <p class="fleet-legend">Haiku workers, one orchestrator, no idle hands — the dispatch model this site was built with.</p>
  </div>
</section>

<style>
  .fleet-viz-section {
    margin-bottom: var(--space-16);
  }

  .section-moral {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .section-moral em {
    font-style: italic;
    color: var(--color-text-tertiary);
  }

  h2 {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-8);
    line-height: var(--leading-tight);
  }

  .viz-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  .fleet-diagram {
    width: 100%;
    max-width: 500px;
    height: auto;
    aspect-ratio: 400 / 300;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    cursor: pointer;
  }

  .fleet-diagram:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .phase-caption {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    min-height: 1.5em;
  }

  #phase-text {
    color: var(--accent);
    font-weight: 500;
  }

  .fleet-legend {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-align: center;
    max-width: 60ch;
    margin: 0;
    line-height: var(--leading-normal);
  }

  /* Reduce motion: show static diagram */
  @media (prefers-reduced-motion: reduce) {
    .orchestrator-node {
      opacity: 1;
    }

    .worker-dot {
      opacity: 1;
    }
  }
</style>

<script is:inline>
(function() {
  const svg = document.querySelector('.fleet-diagram');
  const workersGroup = svg.querySelector('.workers');
  const briefLinesGroup = svg.querySelector('.brief-lines');
  const phaseText = document.getElementById('phase-text');

  const workers = Array.from(workersGroup.querySelectorAll('.worker-dot'));
  const numWorkers = workers.length;

  // Paths: from center (200, 150) to endpoints
  const endpoints = [
    { x: 340, y: 50 },   // top-right
    { x: 360, y: 100 },  // right-upper
    { x: 370, y: 150 },  // right
    { x: 360, y: 200 },  // right-lower
    { x: 340, y: 250 },  // bottom-right
    { x: 80, y: 50 },    // top-left
    { x: 40, y: 100 },   // left
  ];

  const controlPoints = [
    { x: 280, y: 80 },
    { x: 300, y: 100 },
    { x: 300, y: 150 },
    { x: 300, y: 200 },
    { x: 280, y: 220 },
    { x: 220, y: 80 },
    { x: 100, y: 100 },
  ];

  const phases = ['dispatch', 'build', 'verify', 'merge'];
  let currentPhase = 0;
  let animationStartTime = 0;
  let isSwarming = false;
  let swarmTime = 0;
  const swarmDuration = 800; // ms

  // Check if reduced motion is preferred
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function quadraticBezier(t, p0, p1, p2) {
    return (1 - t) * (1 - t) * p0 + 2 * (1 - t) * t * p1 + t * t * p2;
  }

  function getPositionOnPath(t, startIndex) {
    const endpoint = endpoints[startIndex];
    const controlPoint = controlPoints[startIndex];
    const x = quadraticBezier(t, 200, controlPoint.x, endpoint.x);
    const y = quadraticBezier(t, 150, controlPoint.y, endpoint.y);
    return { x, y };
  }

  function drawBriefLine(fromX, fromY, toX, toY) {
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('class', 'brief-line');
    line.setAttribute('x1', fromX);
    line.setAttribute('y1', fromY);
    line.setAttribute('x2', toX);
    line.setAttribute('y2', toY);
    briefLinesGroup.appendChild(line);
    return line;
  }

  function updatePhaseCaption() {
    phaseText.textContent = phases[currentPhase];
  }

  function animate(timestamp) {
    if (!animationStartTime) animationStartTime = timestamp;
    const elapsed = timestamp - animationStartTime;

    // Phase cycling every 3 seconds
    const phaseIndex = Math.floor((elapsed / 3000) % phases.length);
    if (phaseIndex !== currentPhase) {
      currentPhase = phaseIndex;
      updatePhaseCaption();
    }

    // Total cycle: 6 seconds (2s dispatch, 2s work/return, 2s pause)
    const cycleTime = (elapsed % 6000);

    if (cycleTime < 2000) {
      // Dispatch phase: move out
      const t = cycleTime / 2000;
      workers.forEach((worker, idx) => {
        const pos = getPositionOnPath(t, idx);
        worker.setAttribute('cx', pos.x);
        worker.setAttribute('cy', pos.y);
      });
      briefLinesGroup.innerHTML = '';
    } else if (cycleTime < 4000) {
      // Return phase: move back with brief lines
      const t = 1 - (cycleTime - 2000) / 2000;
      briefLinesGroup.innerHTML = '';

      workers.forEach((worker, idx) => {
        const pos = getPositionOnPath(t, idx);
        worker.setAttribute('cx', pos.x);
        worker.setAttribute('cy', pos.y);

        // Draw brief line from worker back to orchestrator
        if (t < 0.9) {
          drawBriefLine(pos.x, pos.y, 200, 150);
        }
      });
    } else {
      // Rest phase: dots return to center
      workers.forEach((worker) => {
        worker.setAttribute('cx', 200);
        worker.setAttribute('cy', 150);
      });
      briefLinesGroup.innerHTML = '';
    }

    // Swarm effect on click
    if (isSwarming) {
      swarmTime += 16; // Approximate frame time
      if (swarmTime < swarmDuration) {
        const swarmT = Math.sin((swarmTime / swarmDuration) * Math.PI);
        workers.forEach((worker, idx) => {
          const baseAngle = (idx / numWorkers) * Math.PI * 2;
          const swarmRadius = 40 * swarmT;
          const swarmX = 200 + Math.cos(baseAngle) * swarmRadius;
          const swarmY = 150 + Math.sin(baseAngle) * swarmRadius;
          worker.setAttribute('cx', swarmX);
          worker.setAttribute('cy', swarmY);
        });
      } else {
        isSwarming = false;
        swarmTime = 0;
      }
    }

    if (!prefersReducedMotion) {
      requestAnimationFrame(animate);
    }
  }

  // Click orchestrator to trigger swarm
  svg.addEventListener('click', (e) => {
    const orchestrator = svg.querySelector('.orchestrator-node');
    const rect = svg.getBoundingClientRect();
    const clickX = (e.clientX - rect.left) / rect.width * 400;
    const clickY = (e.clientY - rect.top) / rect.height * 300;

    // Check if click is near orchestrator
    const dist = Math.sqrt((clickX - 200) ** 2 + (clickY - 150) ** 2);
    if (dist < 20) {
      isSwarming = true;
      swarmTime = 0;
    }
  });

  // Focus ring on keyboard
  svg.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      isSwarming = true;
      swarmTime = 0;
    }
  });

  // Make SVG focusable for keyboard
  svg.setAttribute('tabindex', '0');

  // Start animation
  if (prefersReducedMotion) {
    // Static diagram: show all paths
    workers.forEach((worker, idx) => {
      const endpoint = endpoints[idx];
      worker.setAttribute('cx', endpoint.x);
      worker.setAttribute('cy', endpoint.y);
      drawBriefLine(endpoint.x, endpoint.y, 200, 150);
    });
  } else {
    requestAnimationFrame(animate);
  }
})();
</script>
